# GCP / Vertex AI Claude configuration.
#
# Auth is keyless: local dev uses Application Default Credentials, CI uses
# Workload Identity Federation. There are NO API keys or service-account JSON
# files — never put a credential in this file.
#
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <your-project-id>
#
# Copy to .env.local (gitignored) and fill in your project.

ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
CLOUD_ML_REGION=us-east5
VERTEX_MODEL=claude-opus-4-8

# Run the pipeline with no Vertex calls (stub LLM + fixtures). Set to 0 for live runs.
TAXO_OFFLINE=1

# Live web search for autonomous discovery (https://tavily.com). Without it, discovery
# is operator-seeded; grounding-fetch is in-engine either way. Get a key (tvly-...) and:
TAVILY_API_KEY=
